{
  "bypassPermissions": false,
  "disableBypassPermissionsMode": "disable",
  "fsAccess": {
    "allowedPaths": [
      "."
    ]
  },
  "permissions": {
    "Bash": {
      "deny": [
        "git push",
        "git fetch",
        "git worktree",
        "runpodctl",
        "ssh"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_ARGS\" | grep -qE 'git push|git fetch|git worktree|runpodctl|ssh'; then exit 1; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"status\": \"stopped\"}' > registry/spool/${CLAUDE_RUN_ID:-unknown}_final_state.json || true"
          }
        ]
      }
    ]
  }
}